{
  "app": {
    "name": "Mission Control",
    "timezone": "America/New_York",
    "ownerName": "Your Name"
  },
  "backend": {
    "port": 3001,
    "dataFile": "./data/data.json",
    "adapter": "openclaw"
  },
  "adapter": {
    "openclaw": {
      "binPath": "/opt/homebrew/bin/openclaw",
      "mcBase": "http://localhost:3001",
      "workspaceRoot": "/path/to/.openclaw",
      "cronDir": "/path/to/.openclaw/cron",
      "workspaces": [],
      "agents": []
    },
    "rest": {
      "baseUrl": "http://localhost:4000",
      "token": "",
      "agentRunEndpoint": "/api/run",
      "cronHistoryEndpoint": "/api/cron/history",
      "cronJobsEndpoint": "/api/cron/jobs",
      "recentChangesEndpoint": "/api/changes"
    }
  },
  "frontend": {
    "apiBase": "http://localhost:3001",
    "title": "Mission Control"
  }
}
