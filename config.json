{
  "app": {
    "name": "Mission Control",
    "timezone": "Pacific/Auckland",
    "ownerName": "James Xu"
  },
  "backend": {
    "port": 3001,
    "dataFile": "./data/data.json",
    "adapter": "openclaw"
  },
  "adapter": {
    "openclaw": {
      "binPath": "/opt/homebrew/bin/openclaw",
      "mcBase": "http://localhost:3002",
      "workspaceRoot": "/Users/luckbot/.openclaw",
      "cronDir": "/Users/luckbot/.openclaw/cron",
      "workspaces": [],
      "agents": [
        {
          "id": "coding-agent",
          "model": "github-copilot/claude-sonnet-4.6"
        },
        {
          "id": "research-agent",
          "model": "github-copilot/claude-haiku-4.5"
        }
      ]
    },
    "rest": {
      "baseUrl": "http://localhost:4000",
      "token": "",
      "agentRunEndpoint": "/api/run",
      "cronHistoryEndpoint": "/api/cron/history",
      "cronJobsEndpoint": "/api/cron/jobs",
      "recentChangesEndpoint": "/api/changes"
    },
    "stub": {
      "simulateDelays": false
    }
  },
  "frontend": {
    "apiBase": "http://localhost:3001",
    "title": "Mission Control"
  }
}